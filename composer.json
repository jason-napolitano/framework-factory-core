{
  "name": "framework-factory/core",
  "description": "Framework Factory is a PHP application starter package. The aim is to make building PHP 8 powered applications a breeze.",
  "minimum-stability": "stable",
  "license": "BSD-3-Clause",
  "require": {
    "psr/container": "^2.0.2",
    "php": "^8.5"
  },
  "require-dev": {
    "pestphp/pest": "^4.1",
    "laravel/pint": "^1.27"
  },
  "autoload": {
    "psr-4": {
      "FrameworkFactory\\": "src",
      "Tests\\": "tests"
    }
  },
  "scripts": {
    "pint": "./vendor/bin/pint",
    "pest": "./vendor/bin/pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    },
    "optimize-autoloader": true
  }
}
